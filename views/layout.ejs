<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | SensorDash' : 'SensorDash' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <style>
    body { background-color: #f8f9fa; }
    .navbar-brand { font-weight: 700; letter-spacing: 1px; }
    .widget-card { min-height: 300px; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">SensorDash</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarMain">
        <% if (user) { %>
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">

            <%/* Org switcher */%>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                <% if (activeOrgObj) { %>
                  🏢 <%= activeOrgObj.name %>
                <% } else { %>
                  🏢 No Org
                <% } %>
              </a>
              <ul class="dropdown-menu">
                <% if (userOrgs && userOrgs.length > 0) { %>
                  <% userOrgs.forEach(function(org) { %>
                    <li>
                      <form method="POST" action="/org/switch" style="display:inline;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <input type="hidden" name="orgId" value="<%= org._id %>" />
                        <button type="submit" class="dropdown-item <%= (activeOrg && activeOrg === org._id.toString()) ? 'active' : '' %>">
                          <%= org.name %>
                        </button>
                      </form>
                    </li>
                  <% }); %>
                <% } else { %>
                  <li><span class="dropdown-item text-muted">No organisations</span></li>
                <% } %>
              </ul>
            </li>

            <li class="nav-item">
              <a class="nav-link" href="/dashboards">Dashboards</a>
            </li>

            <%/* Admin menu */%>
            <% if (user.role === 'admin' || user.role === 'lead_admin') { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Admin</a>
                <ul class="dropdown-menu">
                  <li><a class="dropdown-item" href="/admin">Overview</a></li>
                  <li><a class="dropdown-item" href="/admin/users">Users</a></li>
                  <li><a class="dropdown-item" href="/admin/orgs">Organisations</a></li>
                </ul>
              </li>
            <% } %>
          </ul>

          <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
            <li class="nav-item me-2">
              <span class="navbar-text text-light">👤 <%= user.username %></span>
            </li>
            <li class="nav-item">
              <form method="POST" action="/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
              </form>
            </li>
          </ul>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <%/* Flash messages */%>
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <%- body %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
