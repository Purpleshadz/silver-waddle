<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Add Widget to "<%= dashboard.title %>"</h5>
      </div>
      <div class="card-body">
        <form method="POST" action="/dashboards/<%= dashboard._id %>/widgets">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="mb-3">
            <label class="form-label">Widget Title</label>
            <input type="text" class="form-control" name="title" placeholder="e.g. Temperature Sensor A" required />
          </div>

          <div class="mb-3">
            <label class="form-label">Measurement</label>
            <select class="form-select" name="measurement" id="measurementSelect" required>
              <option value="">Loading…</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Tag Key <small class="text-muted">(optional)</small></label>
            <select class="form-select" name="tagKey" id="tagKeySelect">
              <option value="">— none —</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Tag Value <small class="text-muted">(optional)</small></label>
            <input type="text" class="form-control" name="tagValue" id="tagValueInput" placeholder="e.g. sensor_01" />
          </div>

          <div class="mb-3">
            <label class="form-label">Field</label>
            <select class="form-select" name="field" id="fieldSelect" required>
              <option value="">Select a measurement first</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Date Range</label>
            <select class="form-select" name="dateRange">
              <option value="-1h">Last 1 hour</option>
              <option value="-6h">Last 6 hours</option>
              <option value="-24h">Last 24 hours</option>
              <option value="-7d">Last 7 days</option>
              <option value="-30d">Last 30 days</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label">Chart Type</label>
            <select class="form-select" name="chartType">
              <option value="line">Line</option>
              <option value="bar">Bar</option>
            </select>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Add Widget</button>
            <a href="/dashboards/<%= dashboard._id %>/edit" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  const measurementSelect = document.getElementById('measurementSelect');
  const tagKeySelect = document.getElementById('tagKeySelect');
  const fieldSelect = document.getElementById('fieldSelect');

  async function loadMeasurements() {
    try {
      const resp = await fetch('/api/measurements');
      const data = await resp.json();
      measurementSelect.innerHTML = '<option value="">— select —</option>';
      data.forEach(m => {
        const opt = document.createElement('option');
        opt.value = m;
        opt.textContent = m;
        measurementSelect.appendChild(opt);
      });
    } catch (err) {
      measurementSelect.innerHTML = '<option value="">Failed to load</option>';
      console.error('Load measurements error:', err);
    }
  }

  async function loadTagsAndFields(measurement) {
    tagKeySelect.innerHTML = '<option value="">— none —</option>';
    fieldSelect.innerHTML = '<option value="">Loading…</option>';

    try {
      const [tagsResp, fieldsResp] = await Promise.all([
        fetch(`/api/measurements/${encodeURIComponent(measurement)}/tags`),
        fetch(`/api/measurements/${encodeURIComponent(measurement)}/fields`)
      ]);
      const tags = await tagsResp.json();
      const fields = await fieldsResp.json();

      tags.forEach(t => {
        const opt = document.createElement('option');
        opt.value = t;
        opt.textContent = t;
        tagKeySelect.appendChild(opt);
      });

      fieldSelect.innerHTML = '<option value="">— select —</option>';
      fields.forEach(f => {
        const opt = document.createElement('option');
        opt.value = f;
        opt.textContent = f;
        fieldSelect.appendChild(opt);
      });
    } catch (err) {
      fieldSelect.innerHTML = '<option value="">Failed to load</option>';
      console.error('Load tags/fields error:', err);
    }
  }

  measurementSelect.addEventListener('change', () => {
    const val = measurementSelect.value;
    if (val) {
      loadTagsAndFields(val);
    } else {
      tagKeySelect.innerHTML = '<option value="">— none —</option>';
      fieldSelect.innerHTML = '<option value="">Select a measurement first</option>';
    }
  });

  loadMeasurements();
</script>
