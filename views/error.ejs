<div class="row justify-content-center mt-5">
  <div class="col-md-6 text-center">
    <h1 class="display-4 text-danger">⚠️ Error</h1>
    <p class="lead"><%= message %></p>
    <% if (error && error.stack && process && process.env && process.env.NODE_ENV !== 'production') { %>
      <pre class="text-start bg-light p-3 rounded small"><%= error.stack %></pre>
    <% } %>
    <a href="/" class="btn btn-dark mt-3">Go Home</a>
  </div>
</div>
