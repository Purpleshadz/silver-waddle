<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>👤 Users</h2>
  <a href="/admin/users/new" class="btn btn-primary">+ New User</a>
</div>

<% if (users.length === 0) { %>
  <div class="alert alert-info">No users found.</div>
<% } else { %>
  <table class="table table-bordered table-hover bg-white">
    <thead class="table-dark">
      <tr>
        <th>Username</th>
        <th>Role</th>
        <th>Organisations</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(u) { %>
        <tr>
          <td><strong><%= u.username %></strong></td>
          <td>
            <% if (u.role === 'lead_admin') { %>
              <span class="badge bg-danger">lead_admin</span>
            <% } else { %>
              <span class="badge bg-primary">admin</span>
            <% } %>
          </td>
          <td>
            <% if (u.organizations && u.organizations.length > 0) { %>
              <% u.organizations.forEach(function(org) { %>
                <span class="badge bg-secondary me-1"><%= org.name %></span>
              <% }); %>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td><%= u.createdAt ? new Date(u.createdAt).toLocaleDateString() : '—' %></td>
          <td>
            <a href="/admin/users/<%= u._id %>/edit" class="btn btn-sm btn-outline-primary me-1">Edit</a>
            <% if (u._id.toString() !== user.id) { %>
            <form method="POST" action="/admin/users/<%= u._id %>/delete" class="d-inline"
                    onsubmit="return confirm('Warning: This will permanently delete the user and cannot be undone.\n\nDelete user \'<%= u.username %>\'?');">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>
